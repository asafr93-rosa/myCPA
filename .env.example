# Anthropic API Key — required for the AI Advisor and CSV auto-categorization features
# Get yours at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase — required for Google Auth and cloud sync
# Create a project at https://supabase.com, then find these in Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
